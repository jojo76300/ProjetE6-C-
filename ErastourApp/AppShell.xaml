<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ErastourApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ErastourApp"
    xmlns:pages="clr-namespace:ErastourApp.Pages"
    Title="ErastourApp">

    <ShellContent
        Title="Lieux"
        ContentTemplate="{DataTemplate pages:LieuxPage}"
        Route="LieuxPage" />

    <ShellContent
        Title="Voyageurs"
        ContentTemplate="{DataTemplate pages:VoyageursPage}"
        Route="VoyageursPage" />

    <ShellContent
        Title="Transports"
        ContentTemplate="{DataTemplate pages:TransportsPage}"
        Route="TransportsPage" />

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
