<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:ErastourApp.ViewModels"
             xmlns:models="clr-namespace:ErastourApp.Models"
             x:DataType="viewmodel:LieuxViewModel"
             x:Class="ErastourApp.Pages.LieuxInsert"
             Title="LieuxInsert"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header avec logo et user info -->
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" 
              ColumnSpacing="15"
              Padding="0,10">

                <Border Grid.Column="0" 
                    BackgroundColor="#7B3FF2"
                    StrokeThickness="0"
                    WidthRequest="50"
                    HeightRequest="50"
                    StrokeShape="RoundRectangle 25">
                    <Label Text="🚌" 
                       FontSize="24"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="Erastour" 
                       FontSize="20" 
                       FontAttributes="Bold"
                       TextColor="#212121"/>
                    <Label Text="Espace Gestionnaire" 
                       FontSize="12" 
                       TextColor="#6E6E6E"/>
                </VerticalStackLayout>

                <HorizontalStackLayout Grid.Column="2" 
                                  Spacing="8" 
                                  VerticalOptions="Center">
                    <Label Text="👤" 
                       FontSize="20"
                       VerticalOptions="Center"/>
                    <Label Text="{Binding CurrentUserName}" 
                       FontSize="14" 
                       TextColor="#212121"
                       VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Button Grid.Column="3"
                    Text="🚪 Déconnexion"
                    Command="{Binding DeconnexionCommand}"
                    BackgroundColor="#FFF0F0"
                    TextColor="#DC3545"
                    FontSize="12"
                    CornerRadius="8"
                    Padding="15,8"/>
            </Grid>

            <!-- Navigation Tabs -->
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto" 
              ColumnSpacing="30"
              Padding="0,10">

                <Button Grid.Column="0" 
                    Text="Vue d'ensemble"
                    Command="{Binding NavigateToDashboardCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#6E6E6E"
                    FontSize="14"
                    BorderWidth="0"
                    Padding="0"
                    CornerRadius="0"/>

                <Button Grid.Column="1" 
                    Text="👥 Voyageurs"
                    Command="{Binding NavigateToVoyageursCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#6E6E6E"
                    FontSize="14"
                    BorderWidth="0"
                    Padding="0"
                    CornerRadius="0"/>

                <Button Grid.Column="2" 
                    Text="📍 Lieux"
                    Command="{Binding NavigateToLieuxCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#6E6E6E"
                    FontSize="14"
                    FontAttributes="Bold"
                    BorderWidth="0"
                    Padding="0"
                    CornerRadius="0"/>

                <Button Grid.Column="3" 
                    Text="🚗 Transports"
                    Command="{Binding NavigateToTransportsCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#6E6E6E"
                    FontSize="14"
                    BorderWidth="0"
                    Padding="0"
                    CornerRadius="0"/>

                <Button Grid.Column="4" 
                    Text="🛣️ Trajets"
                    Command="{Binding NavigateToTrajetsCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#6E6E6E"
                    FontSize="14"
                    BorderWidth="0"
                    Padding="0"
                    CornerRadius="0"/>
            </Grid>

            <BoxView HeightRequest="1" Color="#E1E1E1" Margin="0,-20,0,0" />

            <!-- Barre de titre de la page avec bouton d'ajout -->
            <Label Grid.Column="0" 
                   Text="Ajouter un lieu" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="#212121"
                   VerticalOptions="Center"/>
            <VerticalStackLayout Spacing="10" Padding="20">
                <Label Text="Nom :" FontSize="18" TextColor="Black" />
                <Entry Text="{Binding Nom}" Background="LightGray" TextColor="Black" />
                <Label Text="Ville :" FontSize="18" TextColor="Black" />
                <Entry Text="{Binding Ville}" Background="LightGray" TextColor="Black" />
                <Label Text="Pays :" FontSize="18" TextColor="Black" />
                <Entry Text="{Binding Pays}" Background="LightGray" TextColor="Black" />
                <Label Text="Code Postal :" FontSize="18" TextColor="Black" />
                <Entry Text="{Binding CP}" Background="LightGray" TextColor="Black" />
                <Label Text="Adresse :" FontSize="18" TextColor="Black" />
                <Entry Text="{Binding Adresse}" Background="LightGray" TextColor="Black" />
                <Label Text="Lien Google Maps :" FontSize="18" TextColor="Black" />
                <Entry Text="{Binding LienMap}" Background="LightGray" TextColor="Black" />
                <Label Text="Commentaire :" FontSize="18" TextColor="Black" />
                <Entry Text="{Binding Commentaire}" Background="LightGray" TextColor="Black" />
                <Button Text="Sauvegarder" Command="{Binding AjouterLieuCommand}" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>